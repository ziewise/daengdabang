NEXT_PUBLIC_DDB_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Signup bot protection. Use the public site key only; never place the secret key
# in a NEXT_PUBLIC_ variable. Production must use a real hostname-bound key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Local development may use Cloudflare's always-pass test site key:
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Production example:
# NEXT_PUBLIC_DDB_API_BASE=https://api.daengdabang.com

# Legal / commerce display values
NEXT_PUBLIC_DDB_MALL_NAME=댕다방
NEXT_PUBLIC_DDB_COMPANY_NAME=댕다방
NEXT_PUBLIC_DDB_REPRESENTATIVE=
NEXT_PUBLIC_DDB_BUSINESS_NUMBER=
NEXT_PUBLIC_DDB_MAIL_ORDER_NUMBER=
NEXT_PUBLIC_DDB_BUSINESS_ADDRESS=
NEXT_PUBLIC_DDB_CS_PHONE=
NEXT_PUBLIC_DDB_CS_EMAIL=
NEXT_PUBLIC_DDB_HOSTING_PROVIDER=GitHub Pages
NEXT_PUBLIC_DDB_COPYRIGHT_NOTICE=Copyright © 2026 댕다방. All rights reserved.
