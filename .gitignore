# =====================================================================
# .gitignore — 댕다방 쇼핑몰 (Next.js 16 + TS + Tailwind v4)
# =====================================================================

# ----- Office 임시 lock 파일 (xlsx 열려 있을 때 자동 생성) -----
~$*.xlsx
~$*.docx
~$*.pptx
.~lock.*

# ----- 의존성 -----
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Next.js 빌드 산출물 -----
/.next/
/out/
/build
/dist
.cache/
.parcel-cache/

# ----- 테스트 -----
/coverage

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- 로그 -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Vercel -----
.vercel

# ----- 환경 변수 (커밋 금지) -----
.env
.env.local
.env.*.local
.env*
*.pem

# ----- IDE -----
# .vscode 전체 아닌 개인 설정만 제외 (settings.json·extensions.json 은 공유)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ----- 임시 / 백업 -----
*.tmp
*.bak
*~
.~*

# ----- 마이그레이션 임시 -----
.gitignore.original
README.original.md
