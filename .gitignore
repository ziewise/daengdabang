# =====================================================================
# .gitignore — 댕다방 쇼핑몰 (Next.js 16 + TS + Tailwind v4)
# =====================================================================

# ----- Office 임시 lock 파일 (xlsx 열려 있을 때 자동 생성) -----
~$*.xlsx
~$*.docx
~$*.pptx
.~lock.*

# ----- 의존성 -----
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Next.js 빌드 산출물 -----
/.next/
/out/
/build
/dist
.cache/
.parcel-cache/

# ----- 테스트 -----
/coverage

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- 로그 -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Vercel -----
.vercel

# ----- 환경 변수 (커밋 금지) -----
.env
.env.local
.env.*.local
.env*
*.pem

# ----- IDE -----
# .vscode 전체 아닌 개인 설정만 제외 (settings.json·extensions.json 은 공유)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ----- 임시 / 백업 -----
*.tmp
*.bak
*~
.~*

# ----- 마이그레이션 임시 -----
.gitignore.original
README.original.md

# ----- 작업자 로컬 이미지 스테이징 -----
# 메인 이미지를 catalog/{folder}/{folder}.png 로 복사하기 전 임시 보관 폴더.
# 한 곳에 모아두고 folder_name 기준 자동 매칭에 사용. push 불필요.
# (배치 N으로 받을 때마다 products_main1, products_main2... 등 추가 가능)
/public/images/products_main/
/public/images/products_main1/
/public/images/products_main2/
/public/images/products_main3/

# pnpm 파일 — 이 프로젝트는 npm 사용 (Cloudflare 빌드가 pnpm 오인 방지)
pnpm-lock.yaml
pnpm-workspace.yaml

# ----- 색상 변환 원본(png) — webp 만 배포 -----
# colors/*.png(색상 원본) + chips.png(칩 분할 소스)는 용량이 커(약 505MB) git·배포에서 제외하고
# 로컬에만 보관한다. scripts/build-colors.py 가 png→webp 변환 + chips.png 분할 후 webp 만 커밋한다.
# 색상 추가·수정 시 로컬 png 로 스크립트를 다시 돌려 재변환하면 된다.
public/images/products/catalog/**/colors/*.png

# 색상 칩 분할 작업 산출물(미리보기/샘플)
data/chips_*.png
